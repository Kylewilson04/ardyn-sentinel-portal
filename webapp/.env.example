# Ardyn AI - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# CanLII API (Canadian Legal Information Institute)
# Get your key from: https://www.canlii.org/en/info/api.html
CANLII_API_KEY=your_canlii_api_key_here

# MCP Configuration
MCP_MODE=tee
MCP_PUBMED_ENABLED=true
MCP_LEGAL_ENABLED=true

# TEE Configuration
TEE_RAG_GATEWAY=http://your_tee_gateway:11434
TEE_OLLAMA_URL=http://your_ollama_url:11434

# Security
TEE_ENFORCEMENT_ENABLED=true
ADS_ENCLAVE_ENABLED=1

# JWT Secret (CRITICAL: Generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
ADS_JWT_SECRET=generate_new_secret_here

# Database Encryption (CRITICAL: Generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
ADS_DB_ENCRYPTION_KEY=generate_new_secret_here

# Session Secret (Generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
ADS_SESSION_SECRET=generate_new_secret_here
